	"authors": [
		"Luxure (Lead dev)",
		"Lumii (Assistance)",
		"Chemthunder (Assistance & fixups)"
	],
	"contact": {
		"sources": "https://github.com/LuxureMC/AuxureLib-1.19.2"
	},
